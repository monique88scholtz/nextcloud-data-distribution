# ── Secrets — NEVER commit these ─────────────────────────────
config/.env
.env
*.env
!config/.env.template
!scripts/folders.env.template

# ── Python ────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── Backups ───────────────────────────────────────────────────
backups/

