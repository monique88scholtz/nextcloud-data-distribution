# =============================================================
#  ENVIRONMENT CONFIGURATION TEMPLATE
#  ─────────────────────────────────────────────────────────────
#  1. Copy this file:  cp config/.env.template config/.env
#  2. Fill in every value marked  ← CHANGE THIS
#  3. NEVER commit config/.env to git  (it's in .gitignore)
#  4. Lock it down:  chmod 600 config/.env
# =============================================================

# ── Server ────────────────────────────────────────────────────
NC_DOMAIN=your-domain.com                  # ← CHANGE THIS
NC_SERVER_IP=0.0.0.0                       # ← CHANGE THIS
NC_TIMEZONE=Africa/Johannesburg
NC_DATA_DIR=/var/www/html/nextcloud/data

# ── Database ──────────────────────────────────────────────────
DB_NAME=nextcloud
DB_USER=nextclouduser
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASS!    # ← CHANGE THIS
DB_HOST=localhost
# Note: No root password needed — MariaDB on Ubuntu uses unix_socket auth

# ── Nextcloud Admin ───────────────────────────────────────────
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASS!  # ← CHANGE THIS

# ── SSL ───────────────────────────────────────────────────────
SSL_EMAIL=your-email@example.com           # ← CHANGE THIS
ENABLE_SSL=false                           # set true once domain is configured

# ── PHP ───────────────────────────────────────────────────────
PHP_MEMORY_LIMIT=1G
PHP_UPLOAD_MAX_FILESIZE=20G
PHP_POST_MAX_SIZE=20G
PHP_MAX_EXECUTION_TIME=3600

# ── Sharing Security ──────────────────────────────────────────
NC_SHARE_ENFORCE_PASSWORD=true
NC_SHARE_ALLOW_RESHARE=false
NC_SHARE_DEFAULT_EXPIRE_DAYS=30
NC_SHARE_HIDE_USERNAME_AUTOCOMPLETE=true

# ── Data Source ───────────────────────────────────────────────
CSV_PATH=/opt/nextcloud-setup/data/client_distribution.csv
DATA_ROOT=/mnt/data

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email Notifications (agent_notify.py) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com                   # ← CHANGE THIS
SMTP_PASSWORD=your_app_password            # ← CHANGE THIS (use app password)
SMTP_FROM=noreply@yourdomain.com
PORTAL_URL=http://YOUR_SERVER_IP           # ← CHANGE THIS

# ── TomTom API (Mapflow) ──────────────────────────────────────
TOMTOM_ACCESS_TOKEN=                       # ← CHANGE THIS
TOMTOM_TIMEOUT=30

# ── MAPIT SFTP (provider FTP server) ─────────────────────────
MAPIT_SFTP_HOST=sftp.yourprovider.com      # ← CHANGE THIS
MAPIT_SFTP_PORT=22
MAPIT_SFTP_USER=your_username              # ← CHANGE THIS
MAPIT_SFTP_PASS=your_password              # ← CHANGE THIS
MAPIT_SFTP_DIR=your/remote/directory       # ← CHANGE THIS
MAPIT_SFTP_DATA_DIR=version_subdir_here    # ← changes each quarter
