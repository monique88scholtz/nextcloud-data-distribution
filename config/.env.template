# =============================================================
#  NEXTCLOUD DATA DISTRIBUTION — ENVIRONMENT TEMPLATE
#  ─────────────────────────────────────────────────────────────
#  1. Copy this file:  cp config/.env.template config/.env
#  2. Fill in every value marked with  ← CHANGE THIS
#  3. NEVER commit config/.env to git  (it's in .gitignore)
# =============================================================

# ── SERVER ────────────────────────────────────────────────────
NC_DOMAIN=your-domain.com                  # ← CHANGE THIS  e.g. cloud.yourcompany.co.za
NC_SERVER_IP=0.0.0.0                       # ← CHANGE THIS  your server's public IP
NC_TIMEZONE=Africa/Johannesburg
NC_DATA_DIR=/var/www/html/nextcloud/data   # where Nextcloud stores files

# ── DATABASE ──────────────────────────────────────────────────
DB_NAME=nextcloud
DB_USER=nextclouduser
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASS!    # ← CHANGE THIS
DB_HOST=localhost
# NOTE: No root password needed — MariaDB on Ubuntu uses unix_socket auth for root.
#       The installer connects as root via sudo (no password), then creates the
#       nextclouduser with the password above. That is the only password you need.

# ── NEXTCLOUD ADMIN ───────────────────────────────────────────
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASS!  # ← CHANGE THIS

# ── SSL ───────────────────────────────────────────────────────
SSL_EMAIL=your-email@example.com           # ← CHANGE THIS
ENABLE_SSL=true                            # set false if no domain yet

# ── PHP ───────────────────────────────────────────────────────
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=10G
PHP_POST_MAX_SIZE=10G
PHP_MAX_EXECUTION_TIME=360

# ── SHARING SECURITY ──────────────────────────────────────────
NC_SHARE_ENFORCE_PASSWORD=true
NC_SHARE_ALLOW_RESHARE=false
NC_SHARE_DEFAULT_EXPIRE_DAYS=30
NC_SHARE_HIDE_USERNAME_AUTOCOMPLETE=true

# ── DATA SOURCE ───────────────────────────────────────────────
# Path to your quarterly CSV on the server (after you scp it up)
CSV_PATH=/opt/nextcloud-setup/data/client_distribution.csv

# Root path where your data folders live on the server
DATA_ROOT=/mnt/data

# ── REDIS ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
